{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "blocks": [
    {
      "alignment": "left",
      "segments": [
        {
          "foreground": "blue",
          "style": "plain",
          "template": "\n@@@      @@@\n  @@@@@@    @@@@@@\n @@@@@@@@  @@@@@@@@\n @@@@ @@@  @@@ @@@@\n  @@@ @@    @@ @@@\n   @@@@      @@@@\n    @@        @@\n",
          "type": "text"
        }
      ],
      "type": "prompt"
    },
    {
      "alignment": "right",
      "segments": [
        {
          "foreground": "white",
          "style": "plain",
          "template": "{{.UserName}}@{{.HostName}}",
          "type": "session"
        }
      ],
      "type": "prompt"
    },
    {
      "alignment": "left",
      "segments": [
        {
          "foreground": "white",
          "properties": {
            "style": "full"
          },
          "style": "plain",
          "template": "\n\n\u276f ",
          "type": "path"
        }
      ],
      "type": "prompt"
    }
  ],
  "final_space": true,
  "version": 2
}